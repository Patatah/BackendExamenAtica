generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model Producto {
  idProducto          Int       @id(map: "PK__producto__07F4A132083D5FB5") @default(autoincrement())
  nombre              String    @db.NVarChar(255)
  urlFoto             String
  descripcion         String?   @db.NVarChar(4000)
  precio              Decimal   @db.Decimal(10, 2)
  stock               Int       @default(0, map: "DF__productos__stock__4AB81AF0")
  categoria           String?   @db.NVarChar(100)
  activo              Boolean   @default(true, map: "DF__productos__activ__4BAC3F29")
  creado              DateTime? @default(now(), map: "DF__productos__cread__4CA06362") @db.DateTime
  ultimaActualizacion DateTime? @default(now(), map: "DF__productos__ultim__4D94879B") @db.DateTime

  @@map("productos")
}

/*
Generado usando tabla sql server
